# Optional: site URL for SEO (defaults to https://grinextrade.com)
# NEXT_PUBLIC_SITE_URL=https://grinextrade.com

# Required for contact/quote form email delivery (Resend.com).
# Without this, forms return success in development but do not send email.
# Get an API key at https://resend.com
RESEND_API_KEY=re_xxxxx

# Optional: verified sender email for Resend (e.g. noreply@yourdomain.com)
# If not set, Resend uses onboarding@resend.dev (development only).
# RESEND_FROM=GrinexTrade <noreply@grinextrade.com>
